/*
 * A collection of passes that operate on the distinct material targets, and composites them into one image.
 *
 * "Pre-sort" passes will operate on individual material targets to implement basic effects.
 * The sort pass will simply composite all targets into a single color and depth texture.
 * "Post-sort" passes will operate on this composited target to implement more core effects.
 */
{
    images: [
    	{
			name: "deferred_solid",
			lod: 0,
			internalFormat: "R11F_G11F_B10F",
			pixelFormat: "RGBA",
			pixelDataType: "UNSIGNED_BYTE",
			target: "TEXTURE_2D",
			texParams: [
				{ name: "TEXTURE_MIN_FILTER", val: "LINEAR" },
				{ name: "TEXTURE_MAG_FILTER", val: "LINEAR" },
				{ name: "TEXTURE_WRAP_S", val: "CLAMP_TO_EDGE" },
				{ name: "TEXTURE_WRAP_T", val: "CLAMP_TO_EDGE" }
			]
		},
		{
			name: "sort",
			lod: 0,
			internalFormat: "RGBA16F",
			pixelFormat: "RGBA",
			pixelDataType: "UNSIGNED_BYTE",
			target: "TEXTURE_2D",
			texParams: [
				{ name: "TEXTURE_MIN_FILTER", val: "LINEAR" },
				{ name: "TEXTURE_MAG_FILTER", val: "LINEAR" },
				{ name: "TEXTURE_WRAP_S", val: "CLAMP_TO_EDGE" },
				{ name: "TEXTURE_WRAP_T", val: "CLAMP_TO_EDGE" }
			]
		},
		{
			name: "composite_depth",
			lod: 0,
			internalFormat: "R32F",
			pixelFormat: "RED",
			pixelDataType: "FLOAT",
			target: "TEXTURE_2D",
			texParams: [
				{ name: "TEXTURE_MIN_FILTER", val: "NEAREST" },
				{ name: "TEXTURE_MAG_FILTER", val: "NEAREST" },
				{ name: "TEXTURE_WRAP_S", val: "CLAMP_TO_EDGE" },
				{ name: "TEXTURE_WRAP_T", val: "CLAMP_TO_EDGE" }
			]
		},
		{
			name: "sort_copy",
			lod: 0,
			internalFormat: "R11F_G11F_B10F",
			pixelFormat: "RGBA",
			pixelDataType: "UNSIGNED_BYTE",
			target: "TEXTURE_2D",
			texParams: [
				{ name: "TEXTURE_MIN_FILTER", val: "LINEAR" },
				{ name: "TEXTURE_MAG_FILTER", val: "LINEAR" },
				{ name: "TEXTURE_WRAP_S", val: "CLAMP_TO_EDGE" },
				{ name: "TEXTURE_WRAP_T", val: "CLAMP_TO_EDGE" }
			]
		}
	],

	framebuffers: [
		{
			name: "deferred_solid",
			colorAttachments: [ { image: "deferred_solid", clearColor: 0x00000000 } ]
		},
		{
			name: "sort",
			colorAttachments: [
				{ image: "sort", clearColor: 0x00000000 },
				{ image: "composite_depth", clearColor: 0x00000000 }
			]
		},
		{
			name: "sort_copy",
			colorAttachments: [ { image: "sort_copy", clearColor: 0x00000000 } ]
		},
	],

	programs: [
		{
			name: "deferred_solid",
			vertexSource: "forgetmenot:shaders/post/frame_full.vert",
			fragmentSource: "forgetmenot:shaders/post/fabulous/deferred_solid.frag",
			samplers: [
				"u_color",
				"u_data",
				"u_depth",

				"u_shadow_map",
				"u_shadow_tex",

				"u_skybox",

				"u_transmittance",
				"u_multiscattering",
				"u_sky_display",

				"u_smooth_uniforms",
			]
		},
		{
			name: "sort",
			vertexSource: "forgetmenot:shaders/post/frame_full.vert",
			fragmentSource: "forgetmenot:shaders/post/fabulous/sort.frag",
			samplers: [
				"u_solid_color",
				"u_solid_depth",
				"u_translucent_color",
				"u_translucent_depth",
				"u_entity_color",
				"u_entity_depth",
				"u_weather_color",
				"u_weather_depth",
				"u_clouds_color",
				"u_clouds_depth",
				"u_particles_color",
				"u_particles_depth",

				"u_data",

				"u_skybox",
			]
		},
		{
			name: "post_sort",
			vertexSource: "forgetmenot:shaders/post/frame_full.vert",
			fragmentSource: "forgetmenot:shaders/post/fabulous/post_sort.frag",
			samplers: [
				"u_color",
				"u_depth",

				"u_transmittance",
				"u_multiscattering",

				"u_shadow_map",
				"u_shadow_tex",

				"u_skybox",
				"u_hi_depth_levels",
				"u_data",

				"u_smooth_uniforms",
				"u_previous_color",
			]
		}
	],

	onResize: {
		passes: [
			{
				name: "clear_sort_copy",
				framebuffer: "sort_copy",
				program: "frex_clear"
			},
		]
	},

	fabulous: {
		passes: [
			{
				name: "deferred_solid",
				program: "deferred_solid",
				framebuffer: "deferred_solid",
				samplerImages: [
					"solid_color",
					"solid_data",
					"solid_depth",

					"shadow_map",
					"shadow_map",

					"skybox",

					"transmittance_lut",
					"multiscattering_lut",
					"sky_display",

					"smooth_uniforms",
				]
			},
			{
				name: "sort",
				program: "sort",
				framebuffer: "sort",
				samplerImages: [
					"deferred_solid",
					"solid_depth",
					"translucent_color",
					"translucent_depth",
					"entity_color",
					"entity_depth",
					"weather_color",
					"weather_depth",
					"clouds_color",
					"clouds_depth",
					"particles_color",
					"particles_depth",

					"composite_data",

					"skybox",
				]
			},
			{
				name: "post_sort",
				program: "post_sort",
				framebuffer: "copy_to_main",
				samplerImages: [
					"sort",
					"composite_depth",

					"transmittance_lut",
					"multiscattering_lut",

					"shadow_map",
					"shadow_map",

					"skybox",
					"hi_depth_levels",
					"composite_data",

					"smooth_uniforms",
					"sort_copy",
				]
			},
			{
				name: "sort_copy",
				program: "copy",
				framebuffer: "sort_copy",
				samplerImages: [
					"solid_color"
				]
			},
		]
	}
}
